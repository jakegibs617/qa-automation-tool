{
  "manifest_version": 3,
  "name": "QA Automation Recorder",
  "version": "0.1.0",
  "description": "Record clicks, inputs, navigation, and selects on any page and export them as QA Automation test steps.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "QA Automation Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["recorder.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
