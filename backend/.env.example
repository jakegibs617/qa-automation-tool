DB_HOST=127.0.0.1
DB_PORT=55432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=qa_automation
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false
# Comma-separated browser origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000
# Local directory for run artifacts (logs, failure screenshots, trace placeholders).
# Defaults to backend/.artifacts when unset.
ARTIFACTS_DIR=
# Redis connection for the BullMQ run queue/worker (docker compose publishes 6379).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional; leave blank for the local Compose Redis, set for managed/secured Redis.
REDIS_PASSWORD=
# How many runs the worker executes concurrently. Defaults to 1 (one browser at a time).
RUN_WORKER_CONCURRENCY=1
# AI test generation. Anthropic can be configured here as a fallback, or saved
# at runtime from the app settings screen. Saved API keys are not returned by
# the API. Leave blank if you only use local Ollama.
ANTHROPIC_API_KEY=
# Default model values used when the settings row is created.
ANTHROPIC_MODEL=
OLLAMA_MODEL=llama3.1
# Local Ollama defaults to http://localhost:11434 for host runs. If the backend
# runs in Docker on macOS/Windows, use http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434
