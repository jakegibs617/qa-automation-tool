{
  "name": "qa-automation-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "smoke:checkpoint2": "ts-node scripts/checkpoint2-smoke.ts",
    "smoke:checkpoint4": "ts-node scripts/checkpoint4-smoke.ts",
    "smoke:checkpoint5": "ts-node scripts/checkpoint5-smoke.ts",
    "smoke:checkpoint7": "ts-node scripts/checkpoint7-smoke.ts",
    "smoke:checkpoint9": "ts-node scripts/checkpoint9-smoke.ts",
    "start": "node dist/main.js",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "schema:sync": "npm run typeorm -- schema:sync"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "bullmq": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.3.2",
    "pg": "^8.0.0",
    "playwright": "^1.44.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
